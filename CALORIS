// ── Score view ────────────────────────────────────────────────────────
function renderScoreView(){
  const container=document.getElementById('score-body');
  if(!container)return;
  container.innerHTML='';
  const cfg=S.configs[S.currentType];
  const tracks=[];
  cfg.oscillators.forEach((osc,i)=>{
    const sLen=osc.steps&&osc.steps.length?osc.steps.length:S.stepCount;
    tracks.push({label:osc.label||('OSC '+(i+1)),color:osc.muted?'#333333':cfg.color,muted:osc.muted,
      steps:resizeSteps(osc.steps,sLen),sLen,melody:osc.melody||[]});
  });
  if(S.hecaActive){
    const sLen=S.heca.steps&&S.heca.steps.length?S.heca.steps.length:S.stepCount;
    tracks.push({label:'≡ HECA',color:S.heca.muted?'#333333':'#ffb347',muted:S.heca.muted,
      steps:resizeSteps(S.heca.steps,sLen),sLen,melody:S.heca.melody||[]});
  }
  if(!tracks.length){container.textContent='No tracks';return;}
  const maxLen=Math.max(...tracks.map(t=>t.sLen));
  const barW=Math.max(1,Math.floor(maxLen/4));
  const markers=div('bar-markers');
  for(let i=0;i<maxLen;i++){
    const d=document.createElement('div');
    d.className='bar-num'+(i%barW===0?' beat':'');
    d.textContent=i%barW===0?Math.floor(i/barW)+1:'';
    markers.appendChild(d);
  }
  container.appendChild(markers);
  tracks.forEach((t,ti)=>{
    const row=div('score-row');
    const lbl=document.createElement('span');
    lbl.className='score-label';
    lbl.style.color=t.color;
    lbl.style.opacity=t.muted?.4:.85;
    if(t.muted) lbl.style.textDecoration='line-through';
    lbl.textContent=t.label;
    const stepsDiv=div('step-grid');
    t.steps.forEach((v,i)=>{
      const b=document.createElement('button');
      b.className='step-btn'+(v===0?'':v<.75?' vel-half':' vel-full');
      b.dataset.track='score-'+ti; b.dataset.step=i; b.dataset.len=t.sLen;
      b.textContent=v===0?'·':v<.75?'½':'■';
      b.style.borderColor=v===0?'#0f03':t.color;
      b.style.color=v===0?'#0f03':t.color;
      if(v>.75) b.style.background=t.color+'bb';
      else if(v>.25) b.style.background=t.color+'55';
      stepsDiv.appendChild(b);
    });
    row.append(lbl,stepsDiv);
    container.appendChild(row);
    if(t.melody.length){
      const mRow=div('score-row');
      const mLbl=document.createElement('span');
      mLbl.className='score-label';
      mLbl.style.color=t.color+'66'; mLbl.textContent='melody';
      const mGrid=document.createElement('div');
      mGrid.style.cssText='display:flex;gap:2px;flex-wrap:wrap';
      t.melody.forEach((slot,i)=>{
        const d=document.createElement('div');
        d.dataset.step=i; d.dataset.mellen=t.melody.length;
        d.style.cssText='min-width:20px;height:14px;border-radius:2px;border:1px solid '+(slot?t.color+'55':t.color+'11')+';background:'+(slot?t.color+'11':'transparent')+';font-size:7px;font-family:monospace;color:'+(slot?t.color:t.color+'22')+';display:flex;align-items:center;justify-content:center;padding:0 2px;white-space:nowrap';
        d.textContent=slot?(slot.note+slot.octave):'·';
        d.className='melody-btn';
        mGrid.appendChild(d);
      });
      mRow.append(mLbl,mGrid);
      container.appendChild(mRow);
    }
  });
}

