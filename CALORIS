  const lenLbl=document.createElement('span');
  lenLbl.style.cssText='font-size:9px;color:#0f03;margin-left:4px';
  lenLbl.textContent='len';
  controls.appendChild(lenLbl);
  [2,3,4,5,6,7,8,12,16].forEach(n=>{
    const lb=document.createElement('button');
    lb.textContent=n; lb.style.cssText='font-size:8px;padding:1px 4px';
    if(melody.length===n){lb.style.borderColor='#0f0';lb.style.color='#0f0';lb.style.background='rgba(0,255,0,0.08)';}
    else{lb.style.borderColor='#0f03';lb.style.color='#0f03';}
    lb.addEventListener('click',()=>{pushUndo();cfg.melody=resizeMelody(melody,n);onChange();});
    controls.appendChild(lb);
  });
  if(melody.length){
    const clr=document.createElement('button');
    clr.textContent='clr'; clr.style.cssText='border-color:#555;color:#555;font-size:8px;padding:1px 4px;margin-left:2px';
    clr.addEventListener('click',()=>{pushUndo();cfg.melody=[];onChange();});
    controls.appendChild(clr);
  }
  headerRow.appendChild(controls);
  container.appendChild(headerRow);

  if(!melody.length){
    const hint=document.createElement('div');
    hint.style.cssText='font-size:9px;color:#0f03;font-style:italic;margin-top:3px';
    hint.textContent='Pick a length above to add a melody';
    container.appendChild(hint);
    return container;
  }

  const grid=document.createElement('div');
  grid.style.cssText='display:flex;gap:2px;flex-wrap:wrap;margin-top:4px';
  melody.forEach((slot,i)=>{
    const b=document.createElement('button');
    const label=slot?(slot.note+slot.octave):'—';
    const inScale=!slot||allowed.includes(slot.note);
    b.className='melody-btn'+(slot?' occupied':'')+(slot&&!inScale?' out-of-scale':'');
    b.dataset.step=i; b.dataset.mellen=melody.length;
    b.textContent=label;
    b.title='Click: next note · Shift+click: octave+1\n'+(slot&&!inScale?'(out of scale)':'');
    b.addEventListener('click',e=>{
      pushUndo();
      if(e.shiftKey){
        if(slot) slot.octave=slot.octave>=7?0:slot.octave+1;
      } else {
        if(!slot){cfg.melody[i]={note:allowed[0],octave:cfg.melodyOctave||3,prob:100};}
        else{
          const idx=allowed.indexOf(slot.note);
          if(idx+1>=allowed.length) cfg.melody[i]=null;
          else cfg.melody[i]={...slot,note:allowed[idx+1]};
        }
      }
      onChange();
    });
    grid.appendChild(b);
  });
  container.appendChild(grid);

  const probRow=document.createElement('div');
  probRow.style.cssText='display:flex;gap:2px;flex-wrap:wrap;margin-top:2px;align-items:center';
  const probLbl=document.createElement('span');
  probLbl.style.cssText='font-size:8px;color:#0f03;margin-right:2px';
  probLbl.textContent='prob:';
  probRow.appendChild(probLbl);
  melody.forEach((slot,i)=>{
    if(!slot){const spacer=document.createElement('div');spacer.style.width='28px';probRow.appendChild(spacer);return;}
    const p=slot.prob!==undefined?slot.prob:100;
    const pb=document.createElement('button');
    pb.textContent=p+'%';
    pb.style.cssText='min-width:28px;height:16px;font-size:7px;padding:0 2px;border-radius:2px;cursor:pointer;font-family:monospace;'+(p<100?'border-color:#f80;color:#f80;background:#1a0d00':'border-color:#0f02;color:#0f04;background:transparent');
    pb.addEventListener('click',()=>{
      const newP=parseInt(prompt('Probability (0-100):',p));
      if(!isNaN(newP)){pushUndo();slot.prob=Math.max(0,Math.min(100,newP));onChange();}
    });
    probRow.appendChild(pb);
  });
  container.appendChild(probRow);

  // Velocity row
  const velRow=document.createElement('div');
  velRow.style.cssText='display:flex;gap:2px;flex-wrap:wrap;margin-top:2px;align-items:center';
  const velLbl=document.createElement('span');
  velLbl.style.cssText='font-size:8px;color:#0f03;margin-right:2px';
  velLbl.textContent='vel:';
  velRow.appendChild(velLbl);
  const VEL_LEVELS=[undefined,1,.75,.5,.25,.1];
  const VEL_LABELS=['—','ff','f','mf','p','pp'];
  const velColors=['#0f02','#0f0','#aaff00','#ff0','#f80','#f44'];
  melody.forEach((slot,i)=>{
    if(!slot){const spacer=document.createElement('div');spacer.style.width='28px';velRow.appendChild(spacer);return;}
    const v=slot.vel;
    const li=VEL_LEVELS.findIndex(l=>l===v);
    const idx=li<0?0:li;
    const vb=document.createElement('button');
    vb.textContent=VEL_LABELS[idx];
    vb.title='Click to cycle velocity: — (inherit) → ff → f → mf → p → pp';
    vb.style.cssText='min-width:28px;height:16px;font-size:7px;padding:0 2px;border-radius:2px;cursor:pointer;font-family:monospace;border-color:'+velColors[idx]+';color:'+velColors[idx]+';background:'+(idx===0?'transparent':'rgba(0,0,0,0.4)');
    vb.addEventListener('click',()=>{
      pushUndo();
      const nextIdx=(idx+1)%VEL_LEVELS.length;
      if(VEL_LEVELS[nextIdx]===undefined) delete slot.vel;
      else slot.vel=VEL_LEVELS[nextIdx];
      onChange();
    });
    velRow.appendChild(vb);
  });
  container.appendChild(velRow);

  return container;
}

