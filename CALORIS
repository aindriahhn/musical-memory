  app.innerHTML='<h1>CALORIS <span style="font-size:11px;opacity:.5">v2</span></h1><div class="subtitle">ambient chiptune composition studio · for WARM / Ἑκατόγατάκιαερες</div><div class="credit">designed &amp; built by Claude (Anthropic) · Web Audio API · no framework · works offline</div>';
  const statusEl=document.createElement('div'); statusEl.id='status'; statusEl.className='status';
  statusEl.textContent='Ready. Press Play to initialise audio.'; app.appendChild(statusEl);

  // ── Oscilloscope panel ────────────────────────────────────────────
  const oscPanelEl=document.createElement('div'); oscPanelEl.className='osc-panel';
  const canvas=document.createElement('canvas');
  oscPanelEl.appendChild(canvas);

  // VU strip
  const vuStrip=document.createElement('div'); vuStrip.className='vu-strip';
  const VU_N=32;
  for(let i=0;i<VU_N;i++){const s=document.createElement('div');s.className='vu-seg';vuStrip.appendChild(s);}
  oscPanelEl.appendChild(vuStrip);

  // Oscilloscope controls overlay
  const oscControls=document.createElement('div'); oscControls.className='osc-controls';
  const waveBtn=document.createElement('button'); waveBtn.textContent='WAVE'; waveBtn.className='active';
  const fftBtn=document.createElement('button'); fftBtn.textContent='FFT';
  waveBtn.addEventListener('click',()=>{oscMode='wave';waveBtn.className='active';fftBtn.className='';});
  fftBtn.addEventListener('click',()=>{oscMode='fft';fftBtn.className='active';waveBtn.className='';});
  oscControls.append(waveBtn,fftBtn);

  const oscLabel=document.createElement('div'); oscLabel.className='osc-label'; oscLabel.textContent='CALORIS SCOPE';
  oscPanelEl.append(oscLabel,oscControls);
  app.appendChild(oscPanelEl);

  // Init oscilloscope after append (so offsetWidth is valid)
  requestAnimationFrame(()=>initOscilloscope(canvas));

  // ── Master controls ────────────────────────────────────────────────
  const masterRow=document.createElement('div');
  masterRow.style.cssText='display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;justify-content:center;align-items:center';

  const playBtn=document.createElement('button'); playBtn.id='play-btn'; playBtn.className='big'; playBtn.textContent='▶ Play';
  playBtn.addEventListener('click',()=>{
    if(S.isPlaying){
      stopAllAudio(); S.isPlaying=false;
      setStatus('■ Stopped');
      updateDynamicUI(); render();
    } else {
      getCtx(); startDungeon(S.currentType);
      if(S.hecaActive) startHeca();
      S.isPlaying=true;
      setStatus('Playing: '+S.configs[S.currentType].name);
      updateDynamicUI(); render();
    }
  });
  const hecaBtn=document.createElement('button'); hecaBtn.className='btn-amber big'; hecaBtn.textContent='≡ cold';
  hecaBtn.addEventListener('click',()=>{
    S.hecaActive=!S.hecaActive;
    hecaBtn.textContent=S.hecaActive?'≡ WARM':'≡ cold';
    hecaBtn.classList.toggle('active',S.hecaActive);
    if(S.isPlaying){if(S.hecaActive)startHeca();else{killGroup(hecaGroup);hecaGroup=null;}}
    setStatus(S.hecaActive?'WARM layer on':'WARM layer off');
    updateDynamicUI();
  });
  const meowBtn=document.createElement('button'); meowBtn.className='big'; meowBtn.style.minWidth='72px'; meowBtn.textContent='MEOW';
  meowBtn.addEventListener('click',()=>{
    const ctx=getCtx(),t=ctx.currentTime,dest=masterGain;
    const o=ctx.createOscillator(),g=ctx.createGain(),d=ctx.createDelay(1),fb=ctx.createGain(),w=ctx.createGain(),dr=ctx.createGain();
    o.type='square';
    o.frequency.setValueAtTime(520,t); o.frequency.exponentialRampToValueAtTime(190,t+.18);
    o.frequency.exponentialRampToValueAtTime(310,t+.32); o.frequency.exponentialRampToValueAtTime(160,t+.55);
    g.gain.setValueAtTime(0,t); g.gain.linearRampToValueAtTime(.22,t+.03);
    g.gain.setValueAtTime(.22,t+.38); g.gain.exponentialRampToValueAtTime(.001,t+.65);
    d.delayTime.value=.22;fb.gain.value=.4;w.gain.value=.35;dr.gain.value=.65;
    o.connect(g);g.connect(dr);dr.connect(dest);g.connect(d);d.connect(fb);fb.connect(d);d.connect(w);w.connect(dest);
    o.start(t);o.stop(t+1.2); setStatus('MEOW');
    setTimeout(()=>setStatus(S.isPlaying?'Playing: '+S.configs[S.currentType].name:'Ready'),1300);
  });
  const masterVolRow=document.createElement('div'); masterVolRow.style.cssText='display:flex;gap:4px;align-items:center';
  const mvLbl=document.createElement('span'); mvLbl.style.cssText='font-size:9px;opacity:.6'; mvLbl.textContent='master';
  const mvSlider=document.createElement('input'); mvSlider.type='range'; mvSlider.min=0; mvSlider.max=1; mvSlider.step=.01; mvSlider.value=S.masterVol; mvSlider.style.cssText='width:80px;accent-color:#0f0;cursor:pointer';mvSlider.dataset.mastervolslider='1';
  mvSlider.addEventListener('input',e=>{S.masterVol=parseFloat(e.target.value);if(masterGain)masterGain.gain.value=S.masterVol;});
  mvSlider.addEventListener('change',()=>pushUndo());
  const clipBtn=document.createElement('button'); clipBtn.dataset.clipbtn='1'; clipBtn.style.cssText='font-size:9px'; clipBtn.textContent=S.clipEnabled?'clip ON':'clip off';
  clipBtn.addEventListener('click',()=>{
    S.clipEnabled=!S.clipEnabled; clipBtn.textContent=S.clipEnabled?'clip ON':'clip off';
    if(masterGain&&clipper&&actx&&analyser){
      try{masterGain.disconnect();}catch(e){}
      try{clipper.disconnect();}catch(e){}
      if(S.clipEnabled){
        masterGain.connect(clipper);clipper.connect(analyser);
      } else {
        masterGain.connect(analyser);
      }
      // analyser→destination is wired once in getCtx; no need to reconnect
    }
  });
  masterVolRow.append(mvLbl,mvSlider,clipBtn);

  const undoBtn=document.createElement('button'); undoBtn.id='undo-btn'; undoBtn.style.cssText='font-size:9px;border-color:#888;color:#888;display:none';
  undoBtn.addEventListener('click',doUndo);

  masterRow.append(playBtn,hecaBtn,meowBtn,masterVolRow,undoBtn); app.appendChild(masterRow);

  // ── Sequencer panel ────────────────────────────────────────────────
  const seqPanel=document.createElement('div'); seqPanel.className='panel yellow';
  const seqHead=document.createElement('div'); seqHead.className='panel-header yellow';
  const seqTitle=document.createElement('span'); seqTitle.textContent='SEQUENCER';
  const seqInfo=document.createElement('span'); seqInfo.id='seq-info'; seqInfo.style.cssText='font-size:9px;opacity:.6';
  seqHead.append(seqTitle,seqInfo); seqPanel.appendChild(seqHead);

  const seqRow1=div('row');
  const seqBtn=document.createElement('button'); seqBtn.id='seq-btn'; seqBtn.className='btn-yellow big'; seqBtn.textContent='▶ Seq'; seqBtn.disabled=true;
  seqBtn.addEventListener('click',()=>{ if(seqRunning)stopSeq(); else startSeq(); });
  seqRow1.appendChild(seqBtn);
  const bpmSlider=makeSlider({label:'BPM',value:S.bpm,min:20,max:300,step:1,unit:' bpm',color:'#ff0',
    onInput:v=>{S.bpm=v;updateSeqInfo();},onCommit:()=>pushUndo()});
  bpmSlider.querySelector('input').dataset.bpmslider='1';
  const swingSlider=makeSlider({label:'Swing',value:S.swing,min:0,max:80,step:1,unit:'ms',color:'#f80',
    onInput:v=>{S.swing=v;updateSeqInfo();},onCommit:()=>pushUndo()});
  swingSlider.querySelector('input').dataset.swingslider='1';
  const bpmWrap=document.createElement('div'); bpmWrap.style.cssText='flex:1;min-width:180px';
  bpmWrap.append(bpmSlider,swingSlider); seqRow1.appendChild(bpmWrap);
  seqPanel.appendChild(seqRow1);

  const svDiv=document.createElement('div'); svDiv.style.marginBottom='5px';
  const svLbl=document.createElement('div'); svLbl.style.cssText='font-size:9px;color:#ff0;opacity:.6;margin-bottom:3px;letter-spacing:.1em'; svLbl.textContent='STEP VALUE';
  const svBtns=document.createElement('div'); svBtns.style.cssText='display:flex;gap:2px;flex-wrap:wrap';
  STEP_VALUES.forEach(sv=>{
    const b=document.createElement('button');
    b.title=sv.name; b.textContent=sv.label;
    b.dataset.svkey=sv.key;
    b.style.cssText='font-size:11px;padding:2px 6px;border-color:#ff03;color:#ff03';
    b.addEventListener('click',()=>{ S.stepValueKey=sv.key; updateDynamicUI(); });
    svBtns.appendChild(b);
  });
  svDiv.append(svLbl,svBtns); seqPanel.appendChild(svDiv);

  const clkDiv=document.createElement('div');
  const clkLbl=document.createElement('div'); clkLbl.style.cssText='font-size:9px;color:#ff0;opacity:.6;margin-bottom:3px;letter-spacing:.1em'; clkLbl.textContent='CLOCK STEPS';
  const clkBtns=document.createElement('div'); clkBtns.style.cssText='display:flex;gap:2px;flex-wrap:wrap';
  STEP_OPTIONS.forEach(n=>{
    const b=document.createElement('button');
    b.textContent=n; b.dataset.clkstep=n;
    b.style.cssText='padding:3px 7px;font-size:10px;border-color:#ff03;color:#ff03;background:transparent';
    b.addEventListener('click',()=>{
      S.stepCount=n; prevVel={};
      if(seqTimer){clearTimeout(seqTimer);seqTimer=null;}
      seqStep=0; S.currentStep=0;
      if(seqRunning) seqTick(0);
      updateDynamicUI();
    });
    clkBtns.appendChild(b);
  });
  clkDiv.append(clkLbl,clkBtns); seqPanel.appendChild(clkDiv);

  const noPlay=document.createElement('div'); noPlay.id='seq-noplay'; noPlay.style.cssText='font-size:10px;color:#555;margin-top:4px'; noPlay.textContent='Start playback to enable sequencer';
  seqPanel.appendChild(noPlay); app.appendChild(seqPanel);

  updateDynamicUI();

  // ── Score panel ────────────────────────────────────────────────────
  const scorePanel=div('panel cyan');
  const scoreHead=document.createElement('div'); scoreHead.className='panel-header cyan';
  const scoreTitle=document.createElement('span'); scoreTitle.textContent='SCORE'; scoreTitle.id='score-title';
  const scoreToggle=document.createElement('button'); scoreToggle.className='btn-cyan'; scoreToggle.textContent='collapse';
  const scoreBody=document.createElement('div'); scoreBody.id='score-body';
  scoreToggle.addEventListener('click',()=>{
    const vis=scoreBody.style.display!=='none';
    scoreBody.style.display=vis?'none':'block';
    scoreToggle.textContent=vis?'expand':'collapse';
  });
  scoreHead.append(scoreTitle,scoreToggle); scorePanel.append(scoreHead,scoreBody);
  app.appendChild(scorePanel);

  // ── Dungeon panel ──────────────────────────────────────────────────
  const dungPanel=div('panel');
  const dungHead=document.createElement('div'); dungHead.className='panel-header';
  dungHead.innerHTML='<span>DUNGEON TYPE</span>';
  dungPanel.appendChild(dungHead);
  const dungTabs=document.createElement('div'); dungTabs.id='dungeon-tabs'; dungTabs.className='tabs';
  dungPanel.appendChild(dungTabs);

  // Biome name + color
  const nameRow=div('row'); nameRow.style.marginBottom='8px';
  const nameLbl=document.createElement('label'); nameLbl.textContent='name'; nameLbl.style.cssText='font-size:9px;opacity:.6;width:40px';
  const nameInput=document.createElement('input'); nameInput.type='text'; nameInput.id='biome-name';
  nameInput.style.cssText='background:transparent;border:none;border-bottom:1px solid #0f04;color:#0f0;font-size:11px;font-family:monospace;flex:1;outline:none';
  nameInput.addEventListener('input',e=>{S.configs[S.currentType].name=e.target.value;renderDungeonTabs();});

  // Color swatch + picker
  const colorWrap=document.createElement('div');
  colorWrap.style.cssText='position:relative;width:18px;height:18px;flex-shrink:0';
  colorWrap.id='biome-color-swatch';
  colorWrap.style.background=S.configs[S.currentType].color;
  colorWrap.style.borderRadius='2px'; colorWrap.style.border='1px solid #0f03'; colorWrap.style.cursor='pointer';
  colorWrap.title='Pick biome colour';
  const colorInput=document.createElement('input'); colorInput.type='color'; colorInput.id='biome-color';
  colorInput.value=S.configs[S.currentType].color;
  colorInput.style.cssText='opacity:0;position:absolute;inset:0;width:100%;height:100%;cursor:pointer;border:none;padding:0';
  colorInput.addEventListener('input',e=>{
    S.configs[S.currentType].color=e.target.value;
    colorWrap.style.background=e.target.value;
    renderDungeonTabs();
    renderOscCards();
  });
  colorInput.addEventListener('change',()=>pushUndo());
  colorWrap.appendChild(colorInput);
  nameRow.append(nameLbl,nameInput,colorWrap);
  dungPanel.appendChild(nameRow);

  // Key/scale
  const ksPanel=document.createElement('div'); ksPanel.style.cssText='margin-bottom:10px;padding:8px;background:#000800;border:1px solid #ff03;border-radius:3px';
  const ksLbl=document.createElement('div'); ksLbl.style.cssText='font-size:9px;color:#ff0;margin-bottom:5px;letter-spacing:.1em;opacity:.7'; ksLbl.textContent='KEY / SCALE';
  const ksBody=document.createElement('div'); ksBody.id='key-scale-body';
  ksPanel.append(ksLbl,ksBody); dungPanel.appendChild(ksPanel);

  const oscCards=document.createElement('div'); oscCards.id='osc-cards';
  dungPanel.appendChild(oscCards);
  app.appendChild(dungPanel);

  // ── Hecatoncattie panel ────────────────────────────────────────────
  const hecaPanel=div('panel amber');
  const hecaHead=document.createElement('div'); hecaHead.className='panel-header amber'; hecaHead.style.cssText='display:flex;gap:6px;align-items:center;font-size:10px;color:#ffb347;border-bottom:1px solid #ffb347;padding-bottom:4px;margin-bottom:8px;letter-spacing:.1em';
  const hecaMuteBtn=document.createElement('button'); hecaMuteBtn.id='heca-mute-btn'; hecaMuteBtn.style.cssText='font-size:9px;padding:1px 4px';
  hecaMuteBtn.textContent=S.heca.muted?'M':'m';
  hecaMuteBtn.addEventListener('click',()=>{
    pushUndo();S.heca.muted=!S.heca.muted;
    if(hecaGroup) applyParam(hecaGroup,'gain',S.heca.muted?0:S.heca.volume);
    render();
  });
  const hecaTitle=document.createElement('span'); hecaTitle.id='heca-title'; hecaTitle.textContent='≡ HECATONCATTIE — cold';
  hecaHead.append(hecaMuteBtn,hecaTitle); hecaPanel.appendChild(hecaHead);
  const hecaBody=document.createElement('div'); hecaBody.id='heca-body';
  hecaPanel.appendChild(hecaBody); app.appendChild(hecaPanel);

  // ── MIDI panel ─────────────────────────────────────────────────────
  const midiPanel=div('panel blue');
  const midiHead=document.createElement('div'); midiHead.className='panel-header'; midiHead.style.borderColor='#0af4'; midiHead.style.color='#0af';
  midiHead.innerHTML='<span>MIDI OUTPUT <span style="font-size:8px;opacity:.5">(Chrome only)</span></span>';
  midiPanel.appendChild(midiHead);
  const midiBody=document.createElement('div'); midiBody.id='midi-body';
  midiPanel.appendChild(midiBody); app.appendChild(midiPanel);

  // ── Crossfade panel ────────────────────────────────────────────────
  const xfPanel=div('panel cyan');
  const xfHead=document.createElement('div'); xfHead.className='panel-header cyan';
  xfHead.textContent='CROSSFADE — 2.5s linear';
  xfPanel.appendChild(xfHead);
  const xfRow=div('flex-wrap');
  const fromLbl=document.createElement('span'); fromLbl.style.cssText='font-size:10px;color:#0f0';
  fromLbl.id='xf-from'; fromLbl.textContent='From: '+S.configs[S.currentType].name;
  const xfArr=document.createElement('span'); xfArr.style.cssText='color:#0ff'; xfArr.textContent='→';
  const xfSel=document.createElement('select'); xfSel.id='xf-sel'; xfSel.style.cssText='flex:1;min-width:120px;border-color:#0ff;color:#0ff';
  Object.entries(S.configs).filter(([k])=>k!==S.currentType).forEach(([k,v])=>{
    const o=document.createElement('option');o.value=k;o.textContent=v.name;xfSel.appendChild(o);
  });
  xfSel.addEventListener('change',e=>{S.crossTarget=e.target.value;});
  const xfBtn=document.createElement('button'); xfBtn.textContent='⟶ Fade'; xfBtn.className='btn-cyan big';
  xfBtn.addEventListener('click',()=>crossfade(S.crossTarget||xfSel.value));
  xfRow.append(fromLbl,xfArr,xfSel,xfBtn); xfPanel.appendChild(xfRow);
  const xfHint=document.createElement('div'); xfHint.style.cssText='font-size:10px;color:#555;margin-top:4px'; xfHint.id='xf-hint'; xfHint.textContent='Start playback to crossfade';
  xfPanel.appendChild(xfHint); app.appendChild(xfPanel);

  // ── Import panel ───────────────────────────────────────────────────
  const impPanel=div('panel');
  const impHead=document.createElement('div'); impHead.className='panel-header'; impHead.style.cssText='display:flex;justify-content:space-between;align-items:center;font-size:10px;color:#0ff;border-bottom:1px solid #0ff4;padding-bottom:4px;margin-bottom:8px;letter-spacing:.1em';
  const impTitle=document.createElement('span'); impTitle.textContent='IMPORT CONFIG';
  const impToggle=document.createElement('button'); impToggle.textContent='open';
  const impBody=document.createElement('div'); impBody.style.display='none';
  const impTA=document.createElement('textarea'); impTA.placeholder='Paste CALORIS JSON here...'; impTA.rows=5;
  const impErr=document.createElement('div'); impErr.style.cssText='font-size:9px;color:#f00;margin-bottom:4px';
  const impBtn=document.createElement('button'); impBtn.textContent='Load Config'; impBtn.style.cssText='border-color:#0f0;color:#0f0';
  impBtn.addEventListener('click',()=>{impErr.textContent='';const err=doImport(impTA.value);if(err){impErr.textContent='Error: '+err;}else{impTA.value='';impBody.style.display='none';impToggle.textContent='open';}});
  impBody.append(impTA,impErr,impBtn);
  impToggle.addEventListener('click',()=>{const vis=impBody.style.display!=='none';impBody.style.display=vis?'none':'block';impToggle.textContent=vis?'open':'close';if(!vis)impErr.textContent='';});
  impHead.append(impTitle,impToggle); impPanel.append(impHead,impBody); app.appendChild(impPanel);

  // ── Export panel ───────────────────────────────────────────────────
  const expPanel=div('panel');
  const expHead=document.createElement('div'); expHead.className='panel-header'; expHead.style.cssText='display:flex;justify-content:space-between;align-items:center;font-size:10px;color:#0ff;border-bottom:1px solid #0ff4;padding-bottom:4px;margin-bottom:8px;letter-spacing:.1em';
  const expTitle=document.createElement('span'); expTitle.textContent='EXPORT';
  const expTabRow=document.createElement('span'); expTabRow.style.cssText='display:flex;gap:3px';
  const expBody=document.createElement('div');
  const expTA=document.createElement('textarea'); expTA.readOnly=true; expTA.rows=8; expTA.style.display='none';
  let curExpTab='json';
  const updateExp=()=>{expTA.value=curExpTab==='json'?getExportJSON():getExportJS();};
  ['JSON','JS'].forEach((lbl,i)=>{
    const b=document.createElement('button');
    b.textContent=lbl; b.style.cssText='font-size:10px;'+(i===0?'border-color:#ff0;color:#ff0':'border-color:#ff03;color:#ff03');
    b.addEventListener('click',()=>{
      curExpTab=lbl.toLowerCase();
      Array.from(expTabRow.children).forEach((c,j)=>{c.style.borderColor=j===i?'#ff0':'#ff03';c.style.color=j===i?'#ff0':'#ff03';});
      updateExp();
    });
    expTabRow.appendChild(b);
  });
  const expCopyBtn=document.createElement('button'); expCopyBtn.textContent='Copy'; expCopyBtn.style.cssText='border-color:#ff0;color:#ff0';
  expCopyBtn.addEventListener('click',()=>{updateExp();if(navigator.clipboard){navigator.clipboard.writeText(expTA.value).then(()=>{expCopyBtn.textContent='✓ Copied';setTimeout(()=>expCopyBtn.textContent='Copy',1500);}).catch(()=>{expTA.style.display='block';expTA.select();expCopyBtn.textContent='Select+copy';setTimeout(()=>expCopyBtn.textContent='Copy',2500);});}else{expTA.style.display='block';expTA.select();expCopyBtn.textContent='Select+copy';setTimeout(()=>expCopyBtn.textContent='Copy',2500);}});
  const expShowBtn=document.createElement('button'); expShowBtn.textContent='Show';
  expShowBtn.addEventListener('click',()=>{const vis=expTA.style.display!=='none';expTA.style.display=vis?'none':'block';expShowBtn.textContent=vis?'Show':'Hide';if(!vis)updateExp();});
  expHead.append(expTitle,expTabRow,expCopyBtn,expShowBtn);
  expBody.appendChild(expTA); expPanel.append(expHead,expBody); app.appendChild(expPanel);

  // ── Footer ─────────────────────────────────────────────────────────
  const foot=document.createElement('div'); foot.className='footer';
  foot.innerHTML='CALORIS v2 — Caloris Basin, Mercury · largest confirmed impact basin on Mercury · named "of heat"<br>built by Claude (Anthropic) for WARM · Ἑκατόγατάκιαερες · 2025<br><span style="opacity:.5">ctrl+z undo · click steps: ·→½→■ · shift+click melody: +1 octave · color swatch: pick biome colour</span>';
  app.appendChild(foot);

  render();
}

buildApp();
</script>
