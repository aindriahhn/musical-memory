function updateSeqInfo(){
  const sv=STEP_VALUES.find(s=>s.key===S.stepValueKey)||STEP_VALUES[5];
  const ms=Math.round((60/S.bpm)*1000*sv.mult);
  const loop=((ms*S.stepCount)/1000).toFixed(2);
  const si=document.getElementById('seq-info');
  if(si) si.textContent=loop+'s · '+ms+'ms/step · '+sv.name+' · clock '+S.stepCount;
}

