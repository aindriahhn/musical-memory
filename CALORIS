function getExportJSON(){
  const sv=STEP_VALUES.find(s=>s.key===S.stepValueKey)||STEP_VALUES[5];
  return JSON.stringify({
    dungeonAudio:S.configs,hecatoncattieAudio:S.heca,
    sequencer:{bpm:S.bpm,stepCount:S.stepCount,swing:S.swing,stepValueKey:S.stepValueKey,stepValueMult:sv.mult,stepValueName:sv.name},
    key:{rootNote:S.rootNote,scaleKey:S.scaleKey,scaleName:SCALES[S.scaleKey].name,notes:getScaleNotes(S.rootNote,S.scaleKey)},
    master:{volume:S.masterVol,clipEnabled:S.clipEnabled},
  },null,2);
}
function getExportJS(){
  const sv=STEP_VALUES.find(s=>s.key===S.stepValueKey)||STEP_VALUES[5];
  const notes=getScaleNotes(S.rootNote,S.scaleKey);
  return [
    '// CALORIS v2 export — '+new Date().toISOString().slice(0,10),
    '// Key: '+S.rootNote+' '+SCALES[S.scaleKey].name+'  BPM: '+S.bpm+'  Step: '+sv.name+' x'+sv.mult.toFixed(4)+'  Clock: '+S.stepCount,
    '// stepCount = clock resolution. Each osc loops at steps.length for polyrhythm.',
    '',
    'const BIOME_AUDIO = '+JSON.stringify(S.configs,null,2)+';',
    'const HECATONCATTIE_AUDIO = '+JSON.stringify(S.heca,null,2)+';',
    'const AUDIO_SEQUENCER = '+JSON.stringify({bpm:S.bpm,stepCount:S.stepCount,swing:S.swing,stepValueKey:S.stepValueKey,stepValueMult:sv.mult},null,2)+';',
    'const AUDIO_KEY = '+JSON.stringify({rootNote:S.rootNote,scaleKey:S.scaleKey,notes:notes},null,2)+';',
    'const AUDIO_MASTER = '+JSON.stringify({volume:S.masterVol,clipEnabled:S.clipEnabled},null,2)+';',
  ].join('\n');
}

function doImport(text){
  try{
    const data=JSON.parse(text);
    if(!data.dungeonAudio) throw new Error('Missing dungeonAudio');
    pushUndo();
    S.configs=data.dungeonAudio; S.heca=data.hecatoncattieAudio||clone(DEFAULT_HECA);
    const sq=data.sequencer||{};
    if(sq.bpm) S.bpm=sq.bpm;
    if(sq.stepCount) S.stepCount=sq.stepCount;
    if(sq.swing!==undefined) S.swing=sq.swing;
    if(sq.stepValueKey&&STEP_VALUES.find(s=>s.key===sq.stepValueKey)) S.stepValueKey=sq.stepValueKey;
    if(data.key){S.rootNote=data.key.rootNote||'C';S.scaleKey=data.key.scaleKey||'chromatic';}
    if(data.master){S.masterVol=data.master.volume||.8;S.clipEnabled=data.master.clipEnabled!==false;}
    if(S.isPlaying){stopAllAudio();S.isPlaying=false;}
    setStatus('Config loaded');
    render();
    return '';
  }catch(e){return e.message;}
}

// ── DOM helpers ───────────────────────────────────────────────────────
const el = (tag,attrs={},children=[]) => {
  const e=document.createElement(tag);
  for(const [k,v] of Object.entries(attrs)){
    if(k==='class') e.className=v;
    else if(k.startsWith('on')) e.addEventListener(k.slice(2),v);
    else e.setAttribute(k,v);
  }
  for(const c of children){
    if(typeof c==='string') e.appendChild(document.createTextNode(c));
    else if(c) e.appendChild(c);
  }
  return e;
};
const div  = (cls,children=[]) => el('div',{class:cls},children);
const span = (cls,text) => { const s=el('span',{class:cls}); s.textContent=text; return s; };
const btn  = (text,cls,onclick) => { const b=el('button',{class:cls,onclick}); b.textContent=text; return b; };

function setStatus(msg){
  const s=document.getElementById('status');
  if(s) s.textContent=msg;
}

function updateStepUI(step){
  const st=document.getElementById('score-title');
  if(st) st.textContent='SCORE'+(seqRunning&&step>=0?' — step '+(step+1)+'/'+S.stepCount:'');
  document.querySelectorAll('.step-btn').forEach(b=>{
    const stepIdx=parseInt(b.dataset.step);
    const sLen=parseInt(b.dataset.len||S.stepCount);
    const isCurrent=step>=0&&seqRunning&&stepIdx===step%sLen;
    b.classList.toggle('current',isCurrent);
    if(isCurrent&&parseFloat(b.dataset.vel||0)>0){
      b.classList.remove('fired'); void b.offsetWidth; b.classList.add('fired');
    }
  });
  document.querySelectorAll('.melody-btn').forEach(b=>{
    const stepIdx=parseInt(b.dataset.step);
    const melLen=parseInt(b.dataset.mellen||1);
    const isCurrent=step>=0&&seqRunning&&stepIdx===step%melLen;
    b.classList.toggle('current',isCurrent);
  });
}

// ── Slider row ────────────────────────────────────────────────────────
function makeSlider(opts){
  const wrap=div('row');
  const lbl=el('label'); lbl.textContent=opts.label; lbl.style.color=opts.color||'#0f0';
  const inp=el('input',{type:'range',min:opts.min,max:opts.max,step:opts.step,id:opts.id||''});
  inp.value=opts.value;
  inp.style.accentColor=opts.color||'#0f0';
  const val=el('span',{class:'val'});
  const fmt=v=>{
    const s=parseFloat(opts.step);
    if(s>=1) return Math.round(v)+(opts.unit||'');
    if(s>=.1) return parseFloat(v).toFixed(1)+(opts.unit||'');
    if(s>=.01) return parseFloat(v).toFixed(2)+(opts.unit||'');
    return parseFloat(v).toFixed(3)+(opts.unit||'');
  };
  val.textContent=fmt(opts.value);
  inp.addEventListener('input',e=>{val.textContent=fmt(e.target.value);if(opts.onInput)opts.onInput(parseFloat(e.target.value));});
  inp.addEventListener('change',e=>{if(opts.onCommit)opts.onCommit(parseFloat(e.target.value));});
  wrap.append(lbl,inp,val);
  return wrap;
}

// ── Step grid ─────────────────────────────────────────────────────────
const STEP_CYCLE=[0,.5,1];
function stepNext(v){const i=STEP_CYCLE.indexOf(v<.25?0:v<.75?.5:1);return STEP_CYCLE[(i+1)%3];}

function makeStepGrid(steps,trackId,stepCount,color,onChange){
  const d=div('step-grid');
  const sLen=steps.length;
  steps.forEach((v,i)=>{
    const b=document.createElement('button');
    b.className='step-btn'+(v===0?'':v<.75?' vel-half':' vel-full');
    b.dataset.track=trackId; b.dataset.step=i; b.dataset.len=sLen; b.dataset.vel=v;
    b.textContent=v===0?'·':v<.75?'½':'■';
    b.style.borderColor=v===0?'#0f03':color;
    b.style.color=v===0?'#0f03':color;
    if(v>.75) b.style.background=color+'bb';
    else if(v>.25) b.style.background=color+'55';
    b.addEventListener('click',()=>{
      steps[i]=stepNext(steps[i]);
      onChange(steps);
    });
    d.appendChild(b);
  });
  return d;
}

function makePatternActions(steps,n,color,onChange){
  const d=div('pattern-actions');
  const mb=(text,action)=>{
    const b=document.createElement('button');
    b.textContent=text; b.style.borderColor=color; b.style.color=color;
    b.addEventListener('click',()=>{
      let newSteps;
      if(action==='copy'){S.clipboard=[...steps];S.hasClipboard=true;render();return;}
      pushUndo();
      if(action==='on') newSteps=Array(n).fill(1);
      else if(action==='off') newSteps=Array(n).fill(0);
      else if(action==='inv') newSteps=steps.map(v=>v>0?0:1);
      else if(action==='alt') newSteps=Array(n).fill(0).map((_,i)=>i%2===0?1:0);
      else if(action==='paste'){if(S.clipboard) newSteps=resizeSteps([...S.clipboard],n);else return;}
      if(newSteps) onChange(newSteps);
    });
    d.appendChild(b);
  };
  mb('on','on'); mb('off','off'); mb('inv','inv'); mb('alt','alt'); mb('cpy','copy');
  const pb=document.createElement('button');
  pb.textContent='pst'; pb.style.borderColor=S.hasClipboard?'#0ff':'#333'; pb.style.color=S.hasClipboard?'#0ff':'#333';
  pb.addEventListener('click',()=>{if(S.clipboard){pushUndo();onChange(resizeSteps([...S.clipboard],n));render();}});
  d.appendChild(pb);
  return d;
}

// ── Melody sequencer ──────────────────────────────────────────────────
function makeMelodyGrid(cfg,trackId,onChange){
