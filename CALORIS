const S = {
  configs: clone(DEFAULT_CONFIGS),
  heca: clone(DEFAULT_HECA),
  currentType: 'normal',
  isPlaying: false,
  hecaActive: false,
  seqRunning: false,
  currentStep: 0,
  stepCount: 8,
  bpm: 60,
  swing: 0,
  stepValueKey: 'e',
  rootNote: 'C',
  scaleKey: 'chromatic',
  masterVol: .8,
  clipEnabled: true,
  midiEnabled: false,
  midiOutputId: null,
  midiOutputs: [],
  crossTarget: 'crypt',
  undoStack: [],
  clipboard: null,
  hasClipboard: false,
};

function pushUndo(){
  S.undoStack.push(JSON.stringify({configs:S.configs,heca:S.heca}));
  if(S.undoStack.length>MAX_UNDO) S.undoStack.shift();
}
function doUndo(){
  if(!S.undoStack.length) return;
  const prev=JSON.parse(S.undoStack.pop());
  S.configs=prev.configs; S.heca=prev.heca;
  if(S.isPlaying){ startDungeon(S.currentType); if(S.hecaActive) startHeca(); }
  render();
}

document.addEventListener('keydown',e=>{
  if((e.ctrlKey||e.metaKey)&&e.key==='z'&&!e.shiftKey){e.preventDefault();doUndo();}
});

// ── Audio control ─────────────────────────────────────────────────────
function startDungeon(type){
  activeGroups.forEach(killGroup); activeGroups=[];
  activeGroups=S.configs[type].oscillators.map(cfg=>createGroup(cfg));
  S.currentType=type;
}
function startHeca(cfg){
  killGroup(hecaGroup);
  hecaGroup=createGroup(cfg||S.heca);
}
function stopAllAudio(){
  stopSeq();
  activeGroups.forEach(killGroup); activeGroups=[];
  killGroup(hecaGroup); hecaGroup=null;
}

// ── Sequencer ─────────────────────────────────────────────────────────
function seqTick(step){
  const sv   = STEP_VALUES.find(s=>s.key===S.stepValueKey)||STEP_VALUES[5];
  const beat = (60/S.bpm)*1000*sv.mult;
  const swMs = step%2===1?S.swing:0;
  const now  = actx?actx.currentTime:0;
  seqStep=step; S.currentStep=step;

  // Beat flash on oscilloscope panel
  const op=document.querySelector('.osc-panel');
  if(op&&step===0){ op.classList.remove('beat-flash'); void op.offsetWidth; op.classList.add('beat-flash'); }

  const cfgs=S.configs[S.currentType].oscillators;
  cfgs.forEach((cfg,i)=>{
    const g=activeGroups[i];
    const steps=resizeSteps(cfg.steps,cfg.steps&&cfg.steps.length?cfg.steps.length:S.stepCount);
    const oscStep=Math.floor(step*(cfg.rateMult||1))%steps.length;
    const vel=steps[oscStep]||0;
    const key=S.currentType+':'+i;
    const prev=prevVel[key]||0;
    // Resolve melody slot first so we can scale gain
    let melVelScale=1;
    let activeSlot=null;
    if(cfg.melody&&cfg.melody.length&&vel>0){
      const slot=cfg.melody[oscStep%cfg.melody.length];
      if(slot&&(slot.prob===undefined||Math.random()*100<slot.prob)){
        activeSlot=slot;
        if(slot.vel!==undefined) melVelScale=slot.vel;
      }
    }
    if(!cfg.muted) applyGain(g,cfg,vel,prev,true,melVelScale);
    else if(g) applyParam(g,'gain',0);
    // Gate time — schedule release before next step fires
    if(!cfg.muted&&vel>0&&(cfg.gateTime||1)<0.99&&g){
      clearTimeout(gateTimers[key]);
      gateTimers[key]=setTimeout(()=>{if(g)applyParam(g,'adsr-off',{r:Math.max(.002,cfg.release||.15)});},beat*(cfg.gateTime||1));
    }
    prevVel[key]=cfg.muted?0:vel;
    if(activeSlot&&g){
      g.osc.frequency.setValueAtTime(noteToHz(activeSlot.note,activeSlot.octave),now);
      if(midiOut){
        const mn=noteToMidi(activeSlot.note,activeSlot.octave),mv=Math.round(vel*melVelScale*127);
        try{midiOut.send([0x90|(i%15),mn,mv]);setTimeout(()=>{try{midiOut.send([0x80|(i%15),mn,0]);}catch(e){}},beat*.85);}catch(e){}
      }
    }
  });

  if(S.hecaActive&&hecaGroup){
    const h=S.heca;
    const steps=resizeSteps(h.steps,h.steps&&h.steps.length?h.steps.length:S.stepCount);
    const hecaStep=Math.floor(step*(h.rateMult||1))%steps.length;
    const vel=steps[hecaStep]||0;
    const prev=prevVel.heca||0;
    let hecaMelVelScale=1;
    let hecaActiveSlot=null;
    if(h.melody&&h.melody.length&&vel>0){
      const slot=h.melody[hecaStep%h.melody.length];
      if(slot&&(slot.prob===undefined||Math.random()*100<slot.prob)){
        hecaActiveSlot=slot;
        if(slot.vel!==undefined) hecaMelVelScale=slot.vel;
      }
    }
    if(!h.muted) applyGain(hecaGroup,h,vel,prev,true,hecaMelVelScale);
    else applyParam(hecaGroup,'gain',0);
    if(!h.muted&&vel>0&&(h.gateTime||1)<0.99&&hecaGroup){
      clearTimeout(gateTimers.heca);
      gateTimers.heca=setTimeout(()=>{if(hecaGroup)applyParam(hecaGroup,'adsr-off',{r:Math.max(.002,h.release||.4)});},beat*(h.gateTime||1));
    }
    prevVel.heca=h.muted?0:vel;
    if(hecaActiveSlot)
      hecaGroup.osc.frequency.setValueAtTime(noteToHz(hecaActiveSlot.note,hecaActiveSlot.octave),now);
  }

  updateStepUI(step);
  const next=(step+1)%S.stepCount;
  seqTimer=setTimeout(()=>seqTick(next),beat+swMs);
}

function startSeq(){
  if(seqTimer){clearTimeout(seqTimer);seqTimer=null;}
  prevVel={};
  seqRunning=true; S.seqRunning=true;
  seqTick(0);
  updateDynamicUI();
  startMidiClock();
}
function stopSeq(){
  if(seqTimer){clearTimeout(seqTimer);seqTimer=null;}
  Object.values(gateTimers).forEach(t=>clearTimeout(t)); gateTimers={};
  seqRunning=false; S.seqRunning=false;
  prevVel={};
  seqStep=0; S.currentStep=0;
  stopMidiClock();
  const now=actx?actx.currentTime:0;
  S.configs[S.currentType].oscillators.forEach((cfg,i)=>{
    const g=activeGroups[i]; if(!g)return;
    if(cfg.muted) applyParam(g,'gain',0);
    else applyParam(g,'adsr-off',{r:Math.max(.002,cfg.release||.15)});
    if(cfg.melody&&cfg.melody.length) g.osc.frequency.setValueAtTime(cfg.freq,now);
  });
  if(S.hecaActive&&hecaGroup){
    const h=S.heca;
    if(h.muted) applyParam(hecaGroup,'gain',0);
    else applyParam(hecaGroup,'adsr-off',{r:Math.max(.002,h.release||.4)});
    if(h.melody&&h.melody.length) hecaGroup.osc.frequency.setValueAtTime(h.freq,now);
  }
  updateStepUI(-1);
  updateDynamicUI();
}

// ── MIDI ──────────────────────────────────────────────────────────────
async function initMidi(){
  if(!navigator.requestMIDIAccess){setStatus('MIDI not supported (Chrome only)');return;}
  try{
    const access=await navigator.requestMIDIAccess();
    S.midiOutputs=[...access.outputs.values()].map(o=>({id:o.id,name:o.name}));
    if(S.midiOutputs.length&&!S.midiOutputId) S.midiOutputId=S.midiOutputs[0].id;
    S.midiEnabled=true;
    updateMidiOutput(access);
    access.onstatechange=()=>{S.midiOutputs=[...access.outputs.values()].map(o=>({id:o.id,name:o.name}));updateMidiOutput(access);renderMidiPanel();};
    setStatus('MIDI ready');
    renderMidiPanel();
  }catch(e){setStatus('MIDI access denied');}
}
function updateMidiOutput(access){
  midiOut=S.midiOutputId?access.outputs.get(S.midiOutputId)||null:null;
}
function startMidiClock(){
  if(!S.midiEnabled||!midiOut)return;
  stopMidiClock();
  const sv=STEP_VALUES.find(s=>s.key===S.stepValueKey)||STEP_VALUES[5];
  const pulseMs=(60/S.bpm)*1000/24;
  midiClockTimer=setInterval(()=>{try{midiOut.send([0xF8]);}catch(e){}},pulseMs);
}
function stopMidiClock(){if(midiClockTimer){clearInterval(midiClockTimer);midiClockTimer=null;}}

// ── Crossfade ─────────────────────────────────────────────────────────
function crossfade(targetKey){
  if(!S.isPlaying){setStatus('Start playback first');return;}
  const ctx=getCtx(),now=ctx.currentTime,dur=2.5;
  activeGroups.forEach(g=>{
    g.mainGain.gain.setValueAtTime(g.mainGain.gain.value,now);
    g.mainGain.gain.linearRampToValueAtTime(0,now+dur);
  });
  const old=[...activeGroups];
  setTimeout(()=>old.forEach(killGroup),(dur+.3)*1000);
  const target=S.configs[targetKey];
  activeGroups=target.oscillators.map(cfg=>{
    const g=createGroup(cfg,0);
    g.mainGain.gain.setValueAtTime(0,now);
    g.mainGain.gain.linearRampToValueAtTime(cfg.volume,now+dur);
    return g;
  });
  prevVel={};
  S.currentType=targetKey;
  setStatus('Fading to '+target.name+'...');
  setTimeout(()=>{setStatus('Playing: '+target.name);render();},dur*1000);
  renderDungeonTabs();
  updateDynamicUI();
}

